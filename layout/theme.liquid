{% assign cartTotal = cart.total_price  | times: 1.2 %}
    {% capture day %}{{ "now" | date: "%a" }}{% endcapture %}
    {% capture hour %}{{ "now" | date: "%H" }}{% endcapture %}
    {% assign hour = hour | plus: 0 %}
    {% assign weekdayDelivery = 1999 %}
    {% assign weekendDelivery = 4000 %}
    {% if hour >= 16 %}
      {% assign timeofday = "after" %}
    {% else %}
      {% assign timeofday = "before" %}
    {% endif %}
    {% if cartTotal >= weekendDelivery %}
      {% assign delivery = "weekend" %}
    {% else %}
      {% if cartTotal < weekendDelivery and cartTotal >= weekdayDelivery %}
        {% assign delivery = "weekday" %}
      {% endif %}
    {% endif %}
  {% case day %}
      {% when "Thur" %}
        {% if timeofday == "before" %}
          {% assign deliveryAmount = weekdayDelivery %}
        {% else %}
          {% assign deliveryAmount = weekendDelivery %}
        {% endif %}
    {% when "Fri" %}
      {% assign deliveryAmount = weekendDelivery %}
    {% when "Sat" %}
  {% else %}
    {% assign deliveryAmount = weekdayDelivery %}
  {% endcase %}
  {% assign javaScriptAmount = deliveryAmount | money_without_currency %}
  <style>
    #deliveryPromoBanner {
      text-align:left; background-color:#ECECEC; padding:10px; margin-bottom:10px; border-radius:7px; font-size:13px; min-height: 7em; display: table; width: calc(100% - 200px); margin-left: 100px;
    }
    #deliveryPromoBanner span {
       margin-top: 10px;
    }
    #deliveryProgressOuter {
      background-color: #FFFFFF; height: 5px; width: calc(100% - 30px); margin-left: auto; margin-right: auto; margin-top: 20px; border-radius: 5px; position: relative; 
    }
    #deliveryProgress, #deliveryProgressNew {
      background-color: #0b76e0; border-radius: 5px; height: 5px; width: {% if cartTotal < deliveryAmount %}{{ deliveryAmount | minus: cartTotal | minus: deliveryAmount | times: -1 | divided_by: deliveryAmount | times: 100 }}{% else %}100{% endif %}%; max-width: 100%
    }
    .deliveryStops {
      position: absolute; width: 20px; height: 20px; border-radius: 15px;  transform: translateY(-13px); border: solid white 4px;
    }
    .lipscore-service-review-testimonial {margin-top: 20px;}
  </style>
  <script>
    function updateShippingBar() {
      setTimeout(function(){
        $.ajax({
          url: "/cart.js",
          type: 'GET',
          dataType: 'json',
          success: function(res) {
              //console.log(res);
            //console.log(res.total_price);
              $('#amountRemaining').html("£" + (parseFloat({{ javaScriptAmount }}) - (res.total_price / 100)).toFixed(2));
              $('#deliveryProgress').css("width", (((((parseFloat({{ javaScriptAmount }}) - (res.total_price / 100)) - parseFloat({{ javaScriptAmount }})) * -1 ) / parseFloat({{ javaScriptAmount }})) * 100) + "%");
          }
        })
      }, 500);
    }
  </script>
