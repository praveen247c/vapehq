.product-sticky-atc {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    background: #fff;
    border-top: 1px solid #e8ebef;
    padding: 10px 16px;
    z-index: 10000;
    align-items: center;
    gap: 12px;
    box-shadow: 0 -4px 16px rgba(0,0,0,.06);
    transform: translateY(100%);
    transition: transform .25s ease;
    display: none;
}
@media screen and (max-width: 719px) {
    .product-sticky-atc { display: flex; }
    .product-sticky-atc.is-visible { transform: translateY(0); }
}
.product-sticky-atc__info { flex: 1 1 auto; min-width: 0; }
.product-sticky-atc__title { font-size: 12px; color: #666; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.product-sticky-atc__price { font-weight: bold; font-size: 15px; }
.product-sticky-atc__btn {
    flex: 0 0 auto;
    border: 0;
    border-radius: 8px;
    background: #0b76e0;
    color: #fff;
    font-weight: 700;
    padding: 0 18px;
    height: 46px;
    cursor: pointer;
    font-size: 15px;
}
</style>

