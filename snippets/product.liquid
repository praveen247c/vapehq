        {% unless is_product_modal %}
          <script>
          (function(){
            var wrap=document.querySelector('[data-ratings-wrap]');
            var el=document.getElementById('lipscore-rating');
            if(!wrap||!el){return;}
            function ready(){return el.querySelector('*')!==null||(el.textContent||'').replace(/\s/g,'')!=='';}
            function reveal(){if(ready()){wrap.style.display='';return true;}return false;}
            if(!reveal()){
              var obs=new MutationObserver(function(){if(reveal()){obs.disconnect();}});
              obs.observe(el,{childList:true,subtree:true});
              setTimeout(function(){obs.disconnect();},8000);
            }
          })();
          </script>
        {% endunless %}
