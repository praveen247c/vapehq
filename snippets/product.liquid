    <div class="product-sticky-atc__title">{{ product.title }}</div>
    <div class="product-sticky-atc__price">{{ price | money }}</div>
  </div>
  <button type="button" class="product-sticky-atc__btn" onclick="var t=document.getElementsByName('product-form')[0]; if(t){t.scrollIntoView({behavior:'smooth'});}">
    {{ 'product.buttons.add_to_cart' | t }}
  </button>
</div>
<script>
(function(){
  var bar = document.getElementById('product-sticky-atc');
  if(!bar) return;
  window.addEventListener('scroll', function(){
    if(window.scrollY >= 700){ bar.classList.add('is-visible'); }
    else { bar.classList.remove('is-visible'); }
  }, {passive:true});
})();
</script>
{% endif %}
