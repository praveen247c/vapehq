        {% if product_available %}
          <script>
          (function(){
            var cdEl=document.querySelector('[data-dispatch-countdown]');
            var dateEl=document.querySelector('[data-dispatch-date]');
            if(!cdEl){return;}
            function fmt(d){return d.toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short'});}
            function nextWeekday(d){var n=new Date(d);do{n.setDate(n.getDate()+1);}while(n.getDay()===0||n.getDay()===6);return n;}
            function tick(){
              var now=new Date();
              var cutoff=new Date(now);cutoff.setHours(16,0,0,0);
              var day=now.getDay();
              var beforeCutoff=(now<cutoff)&&day>=1&&day<=5;
              var dispatch;
              if(beforeCutoff){
                var diff=cutoff-now;
                var h=Math.floor(diff/3600000),m=Math.floor((diff%3600000)/60000);
                cdEl.textContent=(h>0?h+'h ':'')+m+'m';
                dispatch=now;
              }else{
                cdEl.textContent='tomorrow';
                dispatch=nextWeekday(now);
              }
              if(dateEl){dateEl.textContent=fmt(nextWeekday(dispatch));}
            }
            tick();setInterval(tick,60000);
          })();
          </script>
        {% endif %}
