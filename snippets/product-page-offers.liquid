{% comment %}
  Product-page offers as a compact "Buy more, save more" strip.

  Multibuy "{qty}for{price}" tags (e.g. 3for1350, 10for4250, qsalt3for10,
  pod3for999) are parsed generically: qty and total are read from the tag,
  and per-unit price + saving are calculated against product.price. Values
  encoded >= 100 are treated as pence (1350 = £13.50); smaller ones as whole
  pounds (10 = £10). Rows are de-duplicated by quantity and sorted ascending.

  Free-gift / starter-kit offers render as their own rows underneath.
  Brand blue (#0b76e0) is kept.
{% endcomment %}

{%- liquid
  assign built = ''
  assign seen = ''
  for tag in product.tags
    assign core = tag | downcase | remove: 'qsalt' | remove: 'pod'
    if core contains 'for'
      assign parts = core | split: 'for'
      assign q = parts[0] | times: 1
      assign pn = parts[1] | times: 1
      if q > 1 and pn > 0
        assign qkey = ':' | append: q | append: ':'
        unless seen contains qkey
          assign seen = seen | append: qkey
          if pn >= 100
            assign totp = pn
          else
            assign totp = pn | times: 100
          endif
          assign qpad = q | prepend: '000' | slice: -3, 3
          assign built = built | append: '~~' | append: qpad | append: '|' | append: q | append: '|' | append: totp
        endunless
      endif
    endif
  endfor
  assign rows = built | remove_first: '~~' | split: '~~' | sort
-%}

{%- capture specials -%}
  {%- if product.tags contains 'Starter Kit QSalts' -%}<a class="pdp-offer-row pdp-offer-row--gift" href="/collections/qsalts"><i class="fa-solid fa-gift pdp-offer-ic"></i><span><b>FREE 10ml QSalts</b> &mdash; add the device to your cart, then pick your flavour</span></a>{%- endif -%}
  {%- if product.tags contains 'Starter Kit Pure' -%}<a class="pdp-offer-row pdp-offer-row--gift" href="/collections/free-10ml"><i class="fa-solid fa-gift pdp-offer-ic"></i><span><b>FREE 10ml E-Liquid</b> &mdash; choose any bottle in this range</span></a>{%- endif -%}
  {%- if product.tags contains 'Starter Kit Deliciu' -%}<a class="pdp-offer-row pdp-offer-row--gift" href="/collections/3-free-e-liquid"><i class="fa-solid fa-gift pdp-offer-ic"></i><span><b>3 FREE 10ml Salts</b> &mdash; add this device, then pick 3 free e-liquids</span></a>{%- endif -%}
  {%- if product.tags contains '2freeheets' -%}<a class="pdp-offer-row pdp-offer-row--gift" href="/collections/iqos-heets"><i class="fa-solid fa-gift pdp-offer-ic"></i><span><b>2 FREE packs of Heets</b></span></a>{%- endif -%}
  {%- if product.tags contains '2freeterea' -%}<a class="pdp-offer-row pdp-offer-row--gift" href="/collections/iqos-terea"><i class="fa-solid fa-gift pdp-offer-ic"></i><span><b>2 FREE packs of Terea / Delia</b></span></a>{%- endif -%}
  {%- if product.tags contains 'q2bundle' -%}<div class="pdp-offer-row pdp-offer-row--gift"><i class="fa-solid fa-gift pdp-offer-ic"></i><span><b>4 FREE QSalts</b> &mdash; 1 included + 3 of your choice</span></div>{%- endif -%}
{%- endcapture -%}

{%- if rows.size > 0 and rows.first != blank or specials != blank -%}
  <div class="pdp-multibuy" data-product-offers>
    <div class="pdp-multibuy__head">Buy more, save more</div>
    {%- for row in rows -%}
      {%- assign rp = row | split: '|' -%}
      {%- assign q = rp[1] | times: 1 -%}
      {%- assign totp = rp[2] | times: 1 -%}
      {%- assign perp = totp | divided_by: q -%}
      {%- assign savep = product.price | times: q | minus: totp -%}
      <div class="pdp-offer-row">
        <span class="pdp-offer-deal">{{ q }} for {{ totp | money }}</span>
        <span class="pdp-offer-meta">{{ perp | money }} each{% if savep > 0 %} &middot; <b>save {{ savep | money }}</b>{% endif %}</span>
      </div>
    {%- endfor -%}
    {{ specials }}
  </div>
{%- endif -%}
