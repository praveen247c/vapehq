{% render 'breadcrumbs' %}
<style>
  .collectionHeader {
    max-width: 1400px; 
    margin-left: auto; 
    margin-right: auto; 
    margin-bottom: 30px;
  }
  .collectionHeader h1 {
    text-align: center;
  }
  .collectionHeader p {
    text-align: center;
  }
  .outerContainer {
    max-width: 1400px;
    margin-right: auto;
    width: 100%;
    margin-left: auto;
    position: relative;
    z-index: 12;
  }
  .productCardOuter {
    max-height: 100%; 
    height: fit-content; 
    margin: 5px; 
    border: #f2f2f2 1px solid; 
    background-color: white;
  }
  .productCardOuter img {
    
    height: auto; 
    border: black 1px solid; 
    margin: 3px;
  }
  .productCardInner {
    max-height: 100%; 
    background-color: white; 
    padding: 3px;
  }
  @media screen and (min-width: 1024px) {
    .collectionHeader img {
      max-width: 1400px;
      width: 100%;
    }
    .productCardOuter {
      float: left;
      max-width: calc(50% - 1px);
      width: calc(50% - 10px); 
    }
    .productCardOuter img {
      float: left;
      width: calc(50% - 6px); 
    }
    .productCardInner {
      float: right;
      width: calc(50% - 5px); 
      height: 312px;
    }
  }
  @media screen and (max-width: 1023px) {
    .collectionHeader img {
      max-width: 100vw;
      width: 100vw;
    }
    .productCardOuter {
      float: left;
      max-width: 100vw;
      width: calc(100vw - 12px); 
    }
    .productCardOuter img {
      float: left;
      width: calc(50% - 6px);
    }
    .productCardInner {
      float: right;
      width: calc(50% - 5px); 
      height: unset;
    }
    .productCardInnerTop h3 {
      font-size: 15px;
    }
    .productCardInnerMiddle h4 {
      font-size: 13px;
    }
    .productCardInnerBottom button {
      font-size: 13px;
      width: 90%;
    }
  }
  .productCardInnerTop {
    height: calc(25% - 1px) !important; 
    padding: 3px;
  }
  .productCardInnerMiddle {
    height: calc(50% - 1px) !important; 
    padding: 3px;
  }
  .productCardInnerBottom {
    height: calc(25% - 1px) !important; 
    padding: 3px; 
    text-align: center;
  }
  .productCardInnerBottom button {
    margin: auto;
  }
</style>
<div class="collectionHeader">
  <img src="https://cdn.shopify.com/s/files/1/2600/2254/files/Bundle_Selector.jpg?v=1742396688">
  <!--<h1 >{{ collection.title }}</h1>
  <p >{{ collection.description }}</p>-->
</div>
<div class="outerContainer">
  {% for product in collection.products %}
  <div class="productCardOuter" style="@media screen and (min-width: 1024px) {float: {% cycle 'left', 'right' %}; }">
    <img src="{{ product.images[0].src | product_img_url: 'grande' }}" >
    <div class="productCardInner">
      <div class="productCardInnerTop">
        <h3>{{ product.title }}</h3>
      </div>
      <div class="productCardInnerMiddle">
        <h4>{{ product.metafields.bundle_options.options }}</h4>
      </div>
      <div class="productCardInnerBottom">
        <button class="product-form--atc-button mdc-ripple-surface mdc-ripple-upgraded"  onclick="window.location.href = '{{ product.url }}'">{{ product.price | times: 1.2 | money_with_currency }}</button>
      </div>
    </div>
  </div>
  {% endfor %}
  <div style='clear:both;'></div>
</div>
{% schema %}
  {
    "name": "Bundles Collection",
    "settings": []
  }
{% endschema %}