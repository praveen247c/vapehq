{%- capture to_hash -%}
  {{- 'now' | date: '%H' -}}
{%- endcapture -%}
{% render 'breadcrumbs' %}
{% assign to_hash = to_hash | replace: ' ', '' | sha256 %}
{% assign colect = "halloween-savings-2024,5-for-10-disposables" | split: "," %}
{% if colect contains collection.handle %}<div style="
    background-image: url('https://cdn.shopify.com/s/files/1/2600/2254/files/Halloween_Collection_Banner.png?v=1730128419');
    background-repeat: no-repeat;
    background-size: 100% auto;
">{% endif %}
  
<script
  type="application/json"
  data-section-type="static-collection"
  data-section-id="{{ section.id }}"
  data-section-data
>
  {
    "show_filter_product_count": false,
    "product_count": {{ collection.products_count | json }},
    "hash": {{ to_hash | json }},
    "filter_groups": "expand_first_two",
    "filter_style": "tags",
    "no_matched_products_text": {{ 'general.accessibility.no_matched_products' | t: tag: '*tag*' | json }},
    "context": {
      "see_more": {{ 'general.general.see_more' | t | json }},
      "see_less": {{ 'general.general.see_less' | t | json }},
      "grid_list": {{ section.settings.default_view | json }},
      "collectionUrl": {{ collection.url | default: '/collections/all' | json }}
    }
  }
</script>



{% assign show_sidebar = false %}
{% assign show_filters = true %}
{% assign show_filter_trigger = false %}

{% style %}
  #shopify-section-{{ section.id }} .subcollections-list__content {
    grid-template-columns: repeat(7, minmax(auto, 1fr));
  }
  @media only screen and (max-width: 860px) {
    #shopify-section-{{ section.id }} .subcollections-list__content {
      grid-template-columns: repeat(5, minmax(auto, 1fr));
    }
  }
  @media only screen and (max-width: 480px) {
    #shopify-section-{{ section.id }} .subcollections-list__content {
      grid-template-columns: repeat(3, minmax(auto, 1fr));
    }
  }
{% endstyle %}

{% comment %} VapeHQ: modern restyle for the left filter sidebar {% endcomment %}
{%- assign filter_accent = settings.color_links | default: settings.color_button_background | default: '#1a1a1a' -%}
{% style %}
  #shopify-section-{{ section.id }} .productgrid--sidebar {
    font-size: 0.95em;
  }
  @media only screen and (min-width: 769px) {
    #shopify-section-{{ section.id }} .productgrid--sidebar {
      position: -webkit-sticky;
      position: sticky;
      top: 1.5rem;
      align-self: flex-start;
    }
  }

  /* Group cards */
  #shopify-section-{{ section.id }} .productgrid--sidebar-group {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
    background: #fff;
  }
  #shopify-section-{{ section.id }} .productgrid--sidebar-button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.85rem 1rem;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
  }
  #shopify-section-{{ section.id }} .productgrid--sidebar-title--small {
    margin: 0;
    font-size: 0.95em;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  #shopify-section-{{ section.id }} .productgrid--sidebar-icon {
    display: inline-flex;
    transition: transform 0.2s ease;
  }
  #shopify-section-{{ section.id }} .productgrid--sidebar-button[aria-expanded="true"] .productgrid--sidebar-icon {
    transform: rotate(180deg);
  }

  /* Filter rows */
  #shopify-section-{{ section.id }} .filter-group .filter-group--wrapper {
    padding: 0.25rem 0.5rem 0.75rem;
  }
  #shopify-section-{{ section.id }} .filter-item {
    list-style: none;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .filter-item .filter-link,
  #shopify-section-{{ section.id }} .filter-item > a {
    display: flex;
    align-items: center;
    padding: 0.4rem 0.5rem;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    line-height: 1.3;
    transition: background-color 0.15s ease;
  }
  #shopify-section-{{ section.id }} .filter-item .filter-link:hover,
  #shopify-section-{{ section.id }} .filter-item > a:hover {
    background: rgba(0, 0, 0, 0.05);
  }
  #shopify-section-{{ section.id }} .filter-item[aria-current="true"] > a {
    font-weight: 600;
    color: {{ filter_accent }};
  }
  /* Use the theme's native checkbox icon (it draws its own box); just align it. */
  #shopify-section-{{ section.id }} .filter-icon--checkbox {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .filter-text {
    flex: 1 1 auto;
  }
  #shopify-section-{{ section.id }} .filter-item--toggle-more .filter-text--link {
    display: inline-block;
    padding: 0.4rem 0.5rem;
    font-size: 0.85em;
    text-decoration: underline;
    opacity: 0.8;
  }
  #shopify-section-{{ section.id }} .filter-item--hidden {
    display: none;
  }
{% endstyle %}

{% comment %}
  VapeHQ: the left filter sidebar is forced on in code (independent of the
  "Show sidebar" customizer toggle) so it activates on theme import without
  any admin changes. It still only appears when the collection has tags.
{% endcomment %}
{% assign show_filters = true %}

{% if collection.all_tags.size > 0 %}
  {% assign show_filter_trigger = true %}
{% endif %}

{% if section.blocks.size > 0 or collection.all_tags.size > 0 %}
  {% comment %}
    Sidebar shows when there are tags to filter on, or there are menu blocks.
  {% endcomment %}
  {% assign show_sidebar = true %}
{% endif %}

{% assign paginate_by = section.settings.products_per_page_range %}
{% if template contains 'view-24' %}
  {% assign paginate_by = 24 %}
{% elsif template contains 'view-36' %}
  {% assign paginate_by = 36 %}
{% elsif template contains 'view-48' %}
  {% assign paginate_by = 48 %}
{% endif %}

{%- capture collection_classes -%}
  {% if show_sidebar %}
    layout--has-sidebar
  {% else %}
    layout--no-sidebar
  {% endif %}

  {% if section.settings.default_view == 'grid-view' %}
    productgrid-gridview
  {% else %}
    productgrid-listview
  {% endif %}
{%- endcapture -%}



{% paginate collection.products by paginate_by %}
  
