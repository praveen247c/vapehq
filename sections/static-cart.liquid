{% assign is_customer = false %}
{% if shop.customer_accounts_enabled and customer %}
  {% assign is_customer = true %}
{% endif %}

{% assign has_sidebar = false %}
{% assign has_items = false %}
{% assign show_continue_link = false %}

{% if section.blocks.size > 0 %}
  {% assign has_sidebar = true %}
{% endif %}

{% if cart.items.size > 0 %}
  {% assign has_items = true %}
{% endif %}

{% assign continue_url = "https://vapehq.co.uk" %}
{% if settings.continue_shopping_url != blank %}
  {% assign continue_url = settings.continue_shopping_url %}
{% endif %}

{% if settings.continue_url_cart %}
  {% assign show_continue_link = true %}
  {%- capture continue_link_html -%}
    <a class="cart-continue" href="https://vapehq.co.uk">
      {{ 'cart.general.continue_shopping' | t }}
      {% render 'icon-library', id: 'icon-signpost-arrow' %}
    </a>
  {%- endcapture -%}
{% endif %}

{% render 'confetti' %}

<script
  type="application/json"
  data-section-type="static-cart"
  data-section-id="{{ section.id }}"
  data-section-data>
  {
    "settings": {
      "shipping": {{ section.settings.enable_shipping_calc | json }},
      "money_format": {{ shop.money_format | strip_html | json }}
    },
    "shipping": {
      "calculate_shipping": {{ 'cart.shipping.calculate_shipping' | t | json }},
      "calculating": {{ 'cart.shipping.calculating' | t | json }},
      "customer": {{ is_customer | default: false | json }},
      "multiple_rates": {{ 'cart.shipping.multiple_rates' | t: number_of_rates: '*number_of_rates*', address: '*address*', rate: '*rate*' | json }},
      "one_rate": {{ 'cart.shipping.one_rate' | t: address: '*address*' | json }},
      "no_rates": {{ 'cart.shipping.no_rates' | t | json }},
      "rate_value": {{ 'cart.shipping.rate_value' | t: rate_title: '*rate_title*', rate: '*rate*'  | json }},
      "zip": {{ 'cart.shipping.zip' | t | json }},
      "shipment_too_heavy": {{ 'cart.shipping.shipment_too_heavy' | t | json }},
      "error_general": {{ 'cart.shipping.error_general' | t | json }}
    }
  }
</script>

<form
  action="{{ routes.cart_url }}"
  method="post"
  aria-label="cart checkout"
>
  <input type="hidden" name="attributes[cart-time]" id="cart-time" value="">
    <header class="cart-title">
    <div class="cart-title-left">
      <h1>{{ 'cart.general.your_cart' | t }}</h1>
      {% if has_items %}
         {% comment %} <span style="font-size:11px; color:#0b76e0;">Please note: Any special offer discounts will apply during the next step</span> {% endcomment %}
        <div class="cart-title-total--small"></div>
      {% endif %}
    </div>

    {% if has_items or show_continue_link %}
      <div class="cart-title-right">
        {% if has_items %}
          <div class="cart-title-total--large">
            <div class="cart-title-total" data-cart-title-total>
              {{ 'cart.general.subtotal' | t }}
          
         {% if cart.cart_level_discount_applications and cart.total_discount > 0 %}   
          {% assign temp = cart.total_price | times:1.2 %}
          {% for discount_application in cart.cart_level_discount_applications %}
            {% capture temp %} {{ discount_application.total_allocated_amount | times:1.2 | plus: temp }} {% endcapture %}
          {% endfor %}
<span class="cart-original-total" style="text-decoration: line-through"><span class="" data-cart-total id="">
          
          <script>console.log('{{ temp | money }}');</script>
                {{ temp | money }}
              </span></span>
              <span class="cart-total" id="cart_subtotal">{{ cart.total_price | times:1.2 | money }}</span>
              
           {% else %}
              <span class="saso-cart-original-total"><span class="" data-cart-total id="cart_subtotal">{{ cart.total_price | times:1.2 | money }} </span></span>
              <span class="saso-cart-total" id="cart_subtotal_new"></span>
           {% endif %}



              </div>
          </div>

          <button
            class="button-primary cart-title-button"
            name="checkout"
            type="submit"
            onclick="var options = {weekday: 'long', hour: 'numeric', minute: 'numeric'}; let now = new Date().toLocaleDateString('en-GB', options); $('#cart-time').val(now);console.log($('#cart-time').val());"
            aria-label="{{ 'cart.general.checkout' | t }}"
          >
            {% if settings.enable_checkout_lock_icon %}
              {% render 'icon-checkout-lock' %}
            {% else %}
              {% render 'icon-library', id: 'icon-cart' %}
            {% endif %}
            {{ 'cart.general.checkout' | t }}
          </button>
                 

        {% elsif show_continue_link %}
          {{ continue_link_html }}
        {% endif %}
      </div>
    {% endif %}

  </header>
{% if customer.id == 773070979114 or customer.id == 2706234048605 %}{% include 'checkout-upsell-mobile' %}{% endif %}
  {% assign cartTotal = cart.total_price  | times: 1.2 %}
    {% capture day %}{{ "now" | date: "%a" }}{% endcapture %}
    {% capture hour %}{{ "now" | date: "%H" }}{% endcapture %}
    {% assign hour = hour | plus: 0 %}
    {% assign weekdayDelivery = 1999 %}
    {% assign weekendDelivery = 4000 %}
    {% if hour >= 16 %}
      {% assign timeofday = "after" %}
    {% else %}
      {% assign timeofday = "before" %}
    {% endif %}
    {% if cartTotal >= weekendDelivery %}
      {% assign delivery = "weekend" %}
    {% else %}
      {% if cartTotal < weekendDelivery and cartTotal >= weekdayDelivery %}
        {% assign delivery = "weekday" %}
      {% endif %}
    {% endif %}
  {% case day %}
      {% when "Thur" %}
        {% if timeofday == "before" %}
          {% assign deliveryAmount = weekdayDelivery %}
        {% else %}
          {% assign deliveryAmount = weekendDelivery %}
        {% endif %}
    {% when "Fri" %}
      {% assign deliveryAmount = weekendDelivery %}
    {% when "Sat" %}
      {% assign deliveryAmount = weekendDelivery %}
  {% else %}
    {% assign deliveryAmount = weekdayDelivery %}
  {% endcase %}
  <style>
    #deliveryPromoBanner {
      width: 100%; margin-left: unset; display: none;
    }
  </style>
<div id="deliveryPromoBanner" align="center" style="">
            <div style="">
              {% if cartTotal < deliveryAmount %}
               You are <span id="amountRemaining" class="orderbybanneralt" style="font-weight:bold; ">{{ deliveryAmount | minus: cartTotal | money }}</span> away from FREE Next Day Shipping.
              {% else %}
                You qualify for FREE Next Day Shipping.
              {% endif %}
             </div>
            <div id="deliveryProgressOuter" style="">
              <div id="deliveryProgress" style=""></div>
              <div class="deliveryStops" style="left: 0px; background-color: #0b76e0;"></div>
              {% if deliveryAmount == weekendDelivery %}<div class="deliveryStops" style="right: 50%; background-color: #C0C0C0;"></div>{% endif %}
              <div class="deliveryStops" style="right: 0px; background-color: #fcc200;"></div>
            </div>
            <span style="float: left;">£4.99 DPD Delivery</span>
            {% if deliveryAmount == weekendDelivery %}<span style="float: left; margin-left: calc(50% - 115px);">FREE DPD Next Working Day Delivery</span>{% endif %}
            <span style="float: right;">FREE DPD Next Day Delivery (before {% if deliveryAmount == weekendDelivery %}1{% else %}4{% endif %}pm)</span>
            {% assign javaScriptAmount = deliveryAmount | money_without_currency %}
  </div>
{% if customer.id == 773070979114 or customer.id == 2706234048605 %}
  
{% endif %}


  <section class="cartitems--container {% if has_sidebar %}has-sidebar{% endif %}">
    
    <div class="cartitems">
      {% if has_items %}
        {%
          render 'cart-item-list',
          cart: cart
        %}
        
        <div class="cart-total">

          {% if section.settings.enable_order_notes %}
            <div class="cart-ordernote">
              <span class="cart-ordernote-heading">{{ 'cart.general.enter_order_note' | t }}</span>
              <div class="form-field">
                <textarea class="form-field-input form-field-textarea" name="note" id="cart-note">{{ cart.note }}</textarea>
                <label class="form-field-title" for="cart-note">{{ 'cart.general.special_instructions' | t }}</label>
              </div>
            </div>
          {% endif %}

          <div class="cart-final-total">
            {% comment %}
        <ul class="discount-list" data-cart-discounts aria-label="{{ 'product.general.discounts' | t }}">
              {%
                render 'cart-discounts',
                cart: cart
              %}
            </ul>
        {% endcomment %}

            <div class="cart-subtotal" style="margin-bottom:5px;">
              <span>{{ 'cart.general.subtotal' | t }}</span>
             {% if temp %}
            <script>{% for discount_application in cart.cart_level_discount_applications %}console.log('{{ discount_application.title }} - {{ discount_application.total_allocated_amount | money }}');{% endfor %}</script>
               <span class="cart-original-total"><span style="text-decoration: line-through;">{{ temp | money }}</span></span>
               <span style="font-size: 12px;">{% assign counter = 0 %}{% for line_item in cart.items %}{% if line_item.discount_allocations %}{% if counter > 0 %}<br>{% endif %}{{ line_item.title }}
<span class="saso-cart-item-discount-notes" data-key="{{line_item.key}}"></span>
<span class="saso-cart-item-upsell-notes" data-key="{{line_item.key}}"></span>
                                {% assign counter = counter | plus: 1 %}{% endif %}{% endfor %} <font color=red>-{{ cart.total_discount | times:1.2 | money }}</font></span>
               <span class="cart-total" style="margin-top:5px; font-size:25px;">{{ cart.total_price | times:1.2 | money }}</span>
            {% else %}
               <span class="saso-cart-original-total"><span class="" data-cart-total>{{ cart.total_price | times:1.2 | money }}</span></span>
               <span class="saso-cart-total" style="margin-top:5px; font-size:25px;"></span>
            {% endif %}
            </div>



           {% comment %} <p style="float:right; color:#0b76e0; font-weight:bold;">Please note: Any special offer discounts will apply during the next step</p> {% endcomment %}
          </div>
          <div class="cart-shipping">
            {% if cart.requires_shipping %}
              {{ 'cart.general.shipping_at_checkout' | t }}
            {% else %}
              {{ 'cart.general.taxes_at_checkout' | t }}
            {% endif %}

            {% comment %}
              snippets/cart-shipping.liquid has an internal check to see if shipping is required
            {% endcomment %}
            {% if section.settings.enable_shipping_calc %}
              {% render 'cart-shipping' %}
            {% endif %}
          </div>

          <div class="cart-checkout">
        <p>
      <strong>WE AGE VERIFY WITH</strong><br>
      <img src="https://cdn.shopify.com/s/files/1/2600/2254/files/1account-logo.png?v=1706484551" alt="Collection Image" style="width: 150px;">
    </p>
            <button
              class="button-primary"
              type="submit"
              name="checkout"
              onclick="var options = {weekday: 'long', hour: 'numeric', minute: 'numeric'}; let now = new Date().toLocaleDateString('en-GB', options); $('#cart-time').val(now);console.log($('#cart-time').val());"
              aria-label="{{ 'cart.general.checkout' | t }}"
            >
              {% if settings.enable_checkout_lock_icon %}
                {% render 'icon-checkout-lock' %}
              {% else %}
                {% render 'icon-library', id: 'icon-cart' %}
              {% endif %}
              {{ 'cart.general.checkout' | t }}
            </button>

            {% if additional_checkout_buttons %}
              <div class="additional-checkout-buttons">
                {{ content_for_additional_checkout_buttons }}
              </div>
            {% endif %}

            {% if show_continue_link %}
              {{ continue_link_html }}
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="cartitems-empty">
          <div class="cartitems-empty--inner">
            <p>{{ 'cart.general.cart_empty' | t }}</p>

            {% if show_continue_link %}
              <a class="button-primary" href="https://vapehq.co.uk">
                {% render 'icon-library', id: 'icon-cart' %}
                {{ 'cart.general.continue_shopping' | t }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
        </div>

    {% if has_sidebar %}
      <div class="cart-sidebar">
        {% if customer.id == 773070979114 or customer.id == 2706234048605 %}{% include 'checkout-upsell' %}{% endif %} 
        <div style="background-color:#f2f2f2; color:#545454; margin:10px 5px 20px 5px; padding:10px">
          <script>
          
          </script>
          <i class="fas fa-truck fa-lg" style="float:right; color:#9a9a9a; margin-top:8px;" aria-hidden="true"></i><h4 style="color:#0b76e0; margin:5px auto;">GET FREE SHIPPING<br>ON ORDERS OVER £19.99</h4><span style="line-height:1.8;">Spend over £19.99 and we'll cover next working day shipping!</span>
        </div>

      <div style="background-color:#f2f2f2; color:#545454; margin:10px 5px 20px 5px; padding:10px">
          <i class="fa fa-question-circle fa-lg" style="float:right; color:#9a9a9a; margin-top:8px;" aria-hidden="true"></i><h4 style="color:#0b76e0; margin:5px auto;">NEED HELP?</h4><span style="line-height:1.8;">Having trouble with your order? No problem, you can reach us by email & phone. <br> <a style="color:#545454; text-decoration:none; font-weight:bold;" href="/pages/contact-us">Contact us <i class="fa fa-chevron-right"></i></a></span>
        </div>
        
        {% for block in section.blocks %}
          {% if block.type == 'image' %}
            {% assign image = block.settings.image %}

            <article class="cart-sidebar-item">
              {% if image %}
                <a href="/pages/offers">{%
                  render 'rimg',
                  img: image,
                  class: 'cart-sidebar-item-image',
                  size: '445x',
                  lazy: true,
                  canvas: true
                %}</a>
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder--image cart-sidebar-item-image' }}
              {% endif %}
            </article>
          {% endif %} 

          {% comment %}{% if block.type == 'richtext' %}
            <article class="cart-sidebar-item cart-sidebar-item--text rte">
              {{ block.settings.richtext }}
            </article>
          {% endif %}{% endcomment %}

          {% if block.type == 'page' %}
            <article class="cart-sidebar-item cart-sidebar-item--text rte">
              {{ pages[block.settings.page].content }}
            </article>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </section>
</form>

  {% comment %}{% include 'cart-add-on' %}{% endcomment %}

<script id="fsb_js">
  //var bar_container = document.getElementById("bar_container");
  //var bar_contents = document.createElement('div');
  //bar_container.appendChild(bar_contents);
