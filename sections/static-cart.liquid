  {% comment %}
    
  
  function update_freeshipping_bar(){
    console.log("Here");
    
    var bar_contents = document.getElementById("deliveryPromoBanner");
    try {
      var cart_total_el = document.getElementById("cart_subtotal_new");
    }
    catch(err){
      var cart_total_el = document.getElementById("cart_subtotal");
    }
    
    var cart_total_str = cart_total_el.innerHTML.trim();
    var cart_total_arr = cart_total_str.split("");
        cart_total_arr.shift();
    var cart_total_num = cart_total_arr.join("");
    var confetti_el = document.getElementById('confetti');
    //console.log(cart_total_el.innerHTML);
    var current_cart_total = cart_total_el.innerHTML.replace("£", "");//cart_total_num;
    current_cart_total = parseInt(current_cart_total);
    //console.log(current_cart_total, {{ javaScriptAmount }});
    if (current_cart_total >= parseFloat({{ javaScriptAmount }})){
      bar_contents.innerHTML = "CONGRATULATIONS!<br>YOU QUALIFY FOR <span class='orderbybanneralt'>FREE</span> UK SHIPPING <br> <span style='margin-top:20px;'";
      confetti_el.style.display = 'block';
    } else {
      var vat_difference = parseFloat({{ javaScriptAmount }}) - cart_total_num;
      var final_value = vat_difference / 100;
      bar_contents.innerHTML = "YOU'RE JUST <span class='orderbybanneralt'>£" + vat_difference.toFixed(2) + "</span> AWAY FROM FREE SHIPPING.";
      confetti_el.style.display = 'none';
    };
  }{% endcomment %}
    window.addEventListener("load", function() {
    setTimeout(function(){
      try {
        var cart_total_el = document.getElementById("cart_subtotal_new");
      }
      catch(err){
        var cart_total_el = document.getElementById("cart_subtotal");
      }
      try{
        var current_cart_total = parseFloat(cart_total_el.innerHTML.replace("£", ""));
      }
      catch(err){
        var current_cart_total = 0;
      }
      console.log(current_cart_total);
      if(!isNaN(current_cart_total) && current_cart_total != null && current_cart_total != 0){
        $('#amountRemaining').html("£" + (parseFloat({{ javaScriptAmount }}) - current_cart_total).toFixed(2));
        $('#deliveryProgress').css("width", (((((parseFloat({{ javaScriptAmount }}) - current_cart_total) - parseFloat({{ javaScriptAmount }})) * -1 ) / parseFloat({{ javaScriptAmount }})) * 100) + "%");
      }
      else {
        $('#deliveryProgress').css("width", "0%");
      }
      $('#deliveryPromoBanner').css("display", "block");
    }, 1500);
      
  });
  {% comment %} {% else %}
  window.addEventListener("load", function() {
    //console.log("here");
    setTimeout(function(){update_freeshipping_bar();}, 1500);
  });
  {% endif %}{% endcomment %}
  //setInterval(update_freeshipping_bar, 1500);
</script>
          
{% schema %}
{
  "name": "Cart page",
  "class": "cart--section section--canonical",
  "max_blocks": 2,
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_order_notes",
      "label": "Enable order notes text box",
      "default": false
    },
    {
      "type": "header",
      "content": "Shipping estimator"
    },
    {
      "type": "checkbox",
      "id": "enable_shipping_calc",
      "label": "Enable shipping estimator",
      "default": true
    },
    {
      "type": "text",
      "id": "shipping_calc_default_country",
      "label": "Default country",
      "default": "United States"
    }
  ],
  "blocks": [
    {
      "type": "richtext",
      "name": "Rich text",
      "limit": 1,
      "settings": [
        {
          "id": "richtext",
          "type": "richtext",
          "label": "Rich text",
          "default": "<p>Use this section to welcome customers to your store, say a bit about your brand, or share news and seasonal promotions.</p>"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "limit": 1,
      "settings": [
        {
          "id": "image",
          "type": "image_picker",
          "label": "Image"
        }
      ]
    },
    {
      "type": "page",
      "name": "Page",
      "limit": 1,
      "settings": [
        {
          "id": "page",
          "type": "page",
          "label": "Choose page"
        }
      ]
    }
  ]
}

{% endschema %}