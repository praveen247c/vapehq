<style>
  #freebiesAdderHolder {
          display: none;
          position: fixed;
          top: 0px;
          left: 0px;
          width: 100vw;
          height: 100vh;
          background-color: rgba(0,0,0,0.5);
          z-index: 775;
          backdrop-filter: blur(2px);
        }
        #freebiesAdder {
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%,-50%);
          background-color: white;
          padding: 20px;
          padding-top: 0px;
          border: black 1px solid;
        }
        @media only screen and (max-width: 400px) {
          #freebiesAdder {
            width: 100vw;
          }
        }
        @media only screen and (min-width: 401px) and (max-width: 500px) {
          #freebiesAdder {
            width: 90vw;
          }
        }
        #freebiesAdder button {
          margin-top: 15px;
        }
</style>
