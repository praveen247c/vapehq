        function showFreebies(element) {
          var form = element.form; //document.getElementById('product_form_' + productId);
          var productId = form.id.value.split('_').pop();
          if (productId == "41139435110493" || productId == "41139435143261" || productId == "40862737236061"){$("#freebiesRange option[value=pure]").hide();} else {$("#freebiesRange option[value=pure]").show();}
          console.log(form.id.value);
          if (form.id.value != "" ){
              $.ajax({
                url: "//vapehq.sohamcomputerservices.co.uk/RetailVariantIDs.php",
                type: 'get',
                success: function(response) {
                    console.log(response);
                    freebies = response;
                  {% if product.id == 7036790571101 %}
                    loadFlavours("qsalts");
                  {% endif %}
                }, 
                error: function(XMLHttpRequest){
                    console.log('didnt work');
                    console.log(XMLHttpRequest);
                }
            });
            $('#freebiesAdderHolder').css('display', 'block');
          }
        }
        
        function loadFlavours(range) {
          var select = document.getElementById('freebiesFlavour');
          select.innerHTML = "";
          var option = document.createElement('option');
          option.innerHTML = "{{ section.settings.flavorDropdown }}";
          select.appendChild(option);
          Object.keys(freebies[range]).forEach(key => {
            var option = document.createElement('option');
            option.setAttribute('value', key);
            option.innerHTML = key;
            select.appendChild(option);
          });
        }
        
        function loadStrength(range, flavour) {
          var select = document.getElementById('freebiesStength');
          select.innerHTML = "";
          var option = document.createElement('option');
          option.innerHTML = "{{ section.settings.strengthDropdown }}";
          select.appendChild(option);
          Object.keys(freebies[range][flavour]).forEach(key => {
            var option = document.createElement('option');
            option.setAttribute('value', freebies[range][flavour][key]);
            option.innerHTML = key;
            select.appendChild(option);
          });
        }
        
        async function onTheFlyAddToCart(variantId) {
              const result = await fetch("/cart/add.json", {
                  method: "POST",
                  headers: {
                      "Content-Type": "application/json",
                      "Accept": "application/json"
                  },
                  body: JSON.stringify({
                      id: variantId,
                      quantity: 1
                  })
              })
          console.log(result);
          switch (result.status){
            case 200:
              if (typeof $("#freebiesRange option:selected").html() !== 'undefined') {
                alert ('{{ section.settings.confMessagept1 }} ' + $("#freebiesRange option:selected").html() + " - " + $("#freebiesFlavour option:selected").html() + ' {{ section.settings.confMessagept2 }}');
              } else {
                alert ('{{ section.settings.confMessagept1 }} ' + "QSalts - " + $("#freebiesFlavour option:selected").html() + ' {{ section.settings.confMessagept2 }}');
              }
              $('#freebiesAdderHolder').css('display', 'none');
              var temp = document.getElementsByClassName("site-header-cart--count");
              var temp2 = temp[0].getAttribute('data-header-cart-count');
              temp[0].setAttribute('data-header-cart-count', parseInt(temp2) + 1);
              break;
            case 400:
              alert('Looks like Chris broke something!');
              $('#freebiesAdderHolder').css('display', 'none');
              break;
            case 404:
              alert("{{ section.settings.errorMessage }}");
              break;
          }
        }
</script> 
    <div id="freebiesAdderHolder">
      <div id="freebiesAdder">
        <h2>{% if product.id == 7036790571101 %}{{ section.settings.headerTextQsalt }}{% else %}{{ section.settings.headerText }}{% endif %}</h2>
        {% if product.id != 7036790571101 %}
        <select style="margin-top:5px;" id="freebiesRange" class="form-field-input form-field-select form-field-filled" onchange="loadFlavours(this.value);">
          <option value="">{{ section.settings.rangeDropdown }}</option>
          <option value="qsalts">QSalts Nic Salts</option>
          <option id="pureOption" value="pure">Pure E-Liquid</option>
        </select><br>{% endif %}
        <select style="margin-top:5px;" id="freebiesFlavour" class="form-field-input form-field-select form-field-filled" onchange="loadStrength({% if product.id != 7036790571101 %}document.getElementById('freebiesRange').value{% else %}'qsalts'{% endif %}, this.value);"></select><br>
        <select style="margin-top:5px;" id="freebiesStength" class="form-field-input form-field-select form-field-filled" onchange=""></select><br>
        <button onclick="if ($('#freebiesRange').val() != '' && $('#freebiesFlavour').val() != '' && $('#freebiesStength').val() != ''){onTheFlyAddToCart(document.getElementById('freebiesStength').value)};" class="product-form--atc-button"><i class="fa-sharp fa-solid fa-cart-shopping-fast"></i> {{ section.settings.addButton }}</button><button style="background-color: {{ section.settings.noButtonColour }}" onclick="response = confirm('{{ section.settings.noQuestion }}'); if (response) {$('#freebiesAdderHolder').css('display', 'none');}" class="product-form--atc-button"><i class="fa-solid fa-ban"></i> {{ section.settings.noButton }}</button>
      </div>
    </div>
    
