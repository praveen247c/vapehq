    height: 20px;
    margin-top: 5px;
    margin-left: 5px;
    width: 100%;
    display: none;
  }*/
#selectors {
    display: none;
}
  .offersChoice {
    float: right;
    width: auto !important;
    margin: unset !important;
    border: none;
    background: none;
    cursor: pointer;
  }
  #offersSelectorGroup select {
    max-width: 375px;
  }
  #offersFlavour, #offersStength {
    margin-bottom: 5px;
  }
  #selectorOutput {
      margin-top: 10px;
  }
  @media only screen and (max-width: 400px) {
    #offerAdder {
      width: 100vw;
