</style>
<script>
    var offers = {},        
        offerRange = "",
        choices = [],
        choice = 1,
        editing = false,
        beingEdited = 0;

    function inArray(needle, haystack) {
        try {
            haystack.forEach(function (value, index) {
                if(value == needle) {
                    return true;
                }
                if(index == needle) {
                    return true;
                }
            });
            return false;
        }
        catch (err) {
          console.log(err);
          try {
            for( i in haystack) {
              if (i == needle) {
                return true;
              }
              if (haystack[i] == needle) {
                return true;
              }
            }
          }
          catch (err){
            console.log(err);
            var length = haystack.length;
            for(var i = 0; i < length; i++) {
                console.log(haystack[i]);
                if(haystack[i] == needle) return true;
            }
            return false;
          }
          return false;
        }
    }
    
    function showOffer() {
        var form = document.getElementById('product_form_{{ product.id }}');
        if (form.id.value != ""){
            $.ajax({
                url: "//vapehq.sohamcomputerservices.co.uk/RetailSKUs.php?minQty=3",
                type: 'get',
                success: function(response) {
                    console.log(response);
                    offers = response;
                }, 
                error: function(XMLHttpRequest){
                    console.log('didnt work');
                    console.log(XMLHttpRequest);
                }
            });
            $('#offerAdderHolder').css('display', 'block');
        }
    }
        
    function loadFlavours(range) {
        var form = document.getElementById('product_form_{{ product.id }}');
        offerRange = range;
        switch (range) {
            case "pure":
                $('#rangeSelect').html($('#offerAddPure').html());
                break;
            default:
                $('#rangeSelect').html($('#offerAddQsalt').html());
                break;
        }
        ['offerAddQsalt', 'offerAddPure'].forEach(key => {
            $('#' + key).css('display', 'none');
        });
        ['startOver', 'rangeSelect'].forEach(key => {
            $('#' + key).css('display', 'block');
        });

        try{
            var qtySelector = document.getElementById('offersQty');
            for(var i = 1; i < ((form['product-quantity-input'].value * 3) + 1) ; i++) {
                var option = document.createElement('option');
                option.setAttribute('value', i);
                option.innerHTML = i;
                qtySelector.appendChild(option);
            }
        }
        catch(err){console.log(err);}

        var select = document.getElementById('offersFlavour');
        select.innerHTML = "";
        var option = document.createElement('option');
        option.innerHTML = "{{ section.settings.flavorDropdown }}";
        select.appendChild(option);
        Object.keys(offers[range]).forEach(key => {
            if (!inArray(key, choices)){
                var option = document.createElement('option');
                option.setAttribute('value', key);
                if (offerRange == "pure") {option.innerHTML = "Pure - " + key;}
                else {option.innerHTML = key;}
                select.appendChild(option);
            }
        });
        $('#offersFlavour').css('display', 'block');
        $('#selectors').css('display', 'block');
    }
        
    function loadStrength(range, flavour) {
        var select = document.getElementById('offersStength');
        select.innerHTML = "";
        var option = document.createElement('option');
        option.innerHTML = "{{ section.settings.strengthDropdown }}";
        select.appendChild(option);
        Object.keys(offers[range][flavour]).forEach(key => {
            var option = document.createElement('option');
            option.setAttribute('value', offers[range][flavour][key]);
            option.innerHTML = key;
            select.appendChild(option);
        });
        $(select).css("display", "block");
    }

    function getChoice(index){
        var count = 1;
        for(var j in choices) {
            if (count == index){
                return j;
            } 
            else {
                count += 1;
            }
        };
    }

    function reShowSelector(Selector) {
        var form = document.getElementById('product_form_{{ product.id }}'),
            temp = document.getElementById('offersChoice' + Selector),
            removeString = $(temp).children("button").prop("outerHTML"),
            item = temp.innerHTML.replace(removeString, "").split(' - ');
        console.log(item);
        $("#selectors h3").html(item[0]);
        ['offersStength', 'offersQty'].forEach(key=> {
            $('#' + key).css('display', 'block');
        });
        $('#offersFlavour option').each(function(key, elem){
            if(elem.innerHTML == item[1]){
                if($(elem).css('display') == 'none'){
                    $(elem).css('display', 'block');
                }
                document.getElementById('offersFlavour').value = elem.value;
                return;
            }
        });
        $('#offersStength option').each(function(key, elem){
            if(elem.innerHTML == item[2].split(' x ')[0]){
                document.getElementById('offersStength').value = elem.value;
                return;
            }
        });
        var temp = 0;
        for(var j in choices) {temp +=  parseInt(choices[j]);};
        temp -= item[2].split(' x ')[1];
        var qtySelector = document.getElementById('offersQty');
        qtySelector.innerHTML = "";
        var option = document.createElement('option');
        option.innerHTML = "{{ section.settings.quantityDropdown }}";
        qtySelector.appendChild(option);
        for(var i = 1; i < ((form['product-quantity-input'].value * 3) + 1) - temp ; i++) {
            var option = document.createElement('option');
            option.setAttribute('value', i);
            option.innerHTML = i;
            qtySelector.appendChild(option);
        }
        qtySelector.value = item[2].split(' x ')[1];
        editing = true;
        beingEdited = Selector;
    }

    function startOver() {
        ['offersFlavour', 'offersStength', 'offersQty', 'offersChoice', 'offersFlavour', 'selectors', 'startOver', 'rangeSelect', 'offersAddToCart'].forEach(key=> {
            if (!inArray(key, ["offersChoice", "offersSelectorGroup", 'startOver', 'rangeSelect', 'offersAddToCart'])) {
                $('#' + key).val("");
            }
            $('#' + key).css('display', 'none');
        });
        $('#offersChoice1').html("");
        
        choice = 1;
        choices = [];
        $("#selectors h3").html('Choice ' + choice);
        ['offerAddQsalt', 'offerAddPure'].forEach(key => {
            $('#' + key).css('display', 'block');
        });
    }
    
    function arrayLength(arrayName){
        var count = 0;
        for(var j in arrayName) {count +=  1;};
        return count;
    }
    
    function moreSelectorsOrButton() {
        $('#offersAddToCart').css('display', 'none');
        var form = document.getElementById('product_form_{{ product.id }}');
        try {
            if (editing == false) {
                var check = document.getElementById('offersChoice' + choice).innerHTML;
                $('#offersChoice' + choice).html($("#selectors h3").html() + " - " + $("#offersFlavour option:selected").html() + " - " + $("#offersStength option:selected").html() + " x " + $("#offersQty option:selected").html() + '<button class="offersChoice" onclick="reShowSelector(' + choice + ')"><i class="fa-solid fa-chevron-down"></i></button>');
                $('#offersChoice' + choice).css('display', 'block');
                $('#offersSelectorGroup' + choice).css('display', 'block');
                choices[document.getElementById('offersStength').value] = document.getElementById('offersQty').value;
                console.log(choices.length);
                choice = arrayLength(choices) + 1;
                $("#selectors h3").html('Choice ' + choice);
            }
            else {
                var check = document.getElementById('offersChoice' + beingEdited).innerHTML;
                $('#offersChoice' + beingEdited).html($("#selectors h3").html() + " - " + $("#offersFlavour option:selected").html() + " - " + $("#offersStength option:selected").html() + " x " + $("#offersQty option:selected").html() + '<button class="offersChoice" onclick="reShowSelector(' + choice + ')"><i class="fa-solid fa-chevron-down"></i></button>');
                $('#offersChoice' + beingEdited).css('display', 'block');
                $('#offersSelectorGroup' + beingEdited).css('display', 'block');
                choices[document.getElementById('offersStength').value] = document.getElementById('offersQty').value;
                console.log(choices.length);
                choice = arrayLength(choices) + 1;
                editing = false;
                beingEdited = 0;
            }
        }
        catch(err) {
            console.log('catch');
            var offersSelectorGroup = document.createElement('div');
            var newOfferChoice = document.createElement('div');
            newOfferChoice.innerHTML = "Choice " + choice + " - " + $("#offersFlavour option:selected").html() + " - " + $("#offersStength option:selected").html() + " x " + $("#offersQty option:selected").html() + '<button class="offersChoice" onclick="reShowSelector(' + choice + ')"><i class="fa-solid fa-chevron-down"></i></button>';
            offersSelectorGroup.setAttribute('id', 'offersSelectorGroup' + choice);
            newOfferChoice.setAttribute('id', 'offersChoice' + choice);
            offersSelectorGroup.appendChild(newOfferChoice);
            document.getElementById('selectorOutput').appendChild(offersSelectorGroup);
            choices[document.getElementById('offersStength').value] = document.getElementById('offersQty').value;
            choice = arrayLength(choices) + 1;
        }
        var temp = 0;
        for(var j in choices) {temp +=  parseInt(choices[j]);};
        switch (true) {
            case temp < form['product-quantity-input'].value * 3:
                console.log('More needed');
                $("#selectors h3").html("Choice " + choice);
                $("#offersFlavour option:selected").css('display', 'none');
                ['offersStength', 'offersQty'].forEach(key=> {
                    $('#' + key).css('display', 'none');
                });
                ['offersStength', 'offersFlavour'].forEach(key=> {
                    document.getElementById(key).value = "";
                });
                var qtySelector = document.getElementById('offersQty');
                qtySelector.innerHTML = "";
                var option = document.createElement('option');
                option.innerHTML = "{{ section.settings.quantityDropdown }}";
                qtySelector.appendChild(option);
                for(var i = 1; i < ((form['product-quantity-input'].value * 3) + 1) - temp ; i++) {
                    var option = document.createElement('option');
                    option.setAttribute('value', i);
                    option.innerHTML = i;
                    qtySelector.appendChild(option);
                }
                break;
            case temp > form['product-quantity-input'].value * 3:
                console.log('Too Many');
                break;
            default:
                $('#offersAddToCart').css('display', 'block');
                $('#selectors').css('display', 'none');
                break;
        }
    }
    
    function processSelections() {
        order = {};
        $.ajax({
          url:'/cart.js', 
          type:'GET',
          error: function(){}, 
          success: 
            function(result){
              var results = JSON.parse(result)
              for(i in choices) {
                if (inArray("QONE-BUNDLE-" + i, results.attributes)){
                    order["QONE-BUNDLE-" + i] = parseInt(choices[i]) + parseInt(results.attributes["QONE-BUNDLE-" + i]);
                }
                else {
                    order["QONE-BUNDLE-" + i] = parseInt(choices[i]);
                }
              }
              onTheFlyAddToCart(order);
            }
        });
    }
    
    async function onTheFlyAddToCart(order) {
        data = {
            'attributes': order
        };
        console.log(data);
        const result = await fetch("/cart/update.json", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "Accept": "application/json"
            },
            body: JSON.stringify(data)
        });
        console.log(result);
        switch (result.status){
            case 200:
                alert("{{ section.settings.confMessage }}");
                $('#offerAdderHolder').css('display', 'none');
                $.ajax({
                  url:'/cart.js', 
                  type:'GET',
                  error: function(){}, 
                  success: 
                    function(result2){
                      var results = JSON.parse(result2);
                      console.log(results);
                      var temp = document.getElementsByClassName("site-header-cart--count");
                      temp[0].setAttribute('data-header-cart-count', results.item_count);
                    }
                });
                break;
            case 400:
                alert('Looks like Chris broke something!');
                $('#offerAdderHolder').css('display', 'none');
                break;
            case 404:
                alert("{{ section.settings.errorMessage }}");
                break;
        }
    }
  
    $( document ).ready(function() {showOffer();});
</script> 
    <div id="offerAdderHolder">
      <div id="offerAdder">
        <h2>{{ section.settings.headerText }}</h2>
        <h3 id="rangeSelect"></h3><button id="startOver" onclick="startOver()" class="product-form--atc-button">{{ section.settings.startOverButton }}</button>
        <button id="offerAddQsalt" onclick="loadFlavours('qsalts');" class="product-form--atc-button">{{ section.settings.qsaltsButton }}</button>
        <button id="offerAddPure" onclick="loadFlavours('pure');" class="product-form--atc-button">{{ section.settings.pureButton }}</button>
        <div id="selectorOutput">
            <div id="offersSelectorGroup1" style="display: none;">
              <div id="offersChoice1" class=""></div>
            </div>
        </div>
        <div id="selectors">
            <h3>Choice 1</h3>
            <select style="display: none;" id="offersFlavour" class="form-field-input form-field-select form-field-filled" onchange="loadStrength(offerRange, this.value);"></select>
            <select style="display: none;" id="offersStength" class="form-field-input form-field-select form-field-filled" onchange="$('#offersQty').css('display', 'block'); $('#offersQty').width($('#offerAdder button').width());"></select>
            <select style="display: none;" id="offersQty" class="form-field-input form-field-select form-field-filled" onchange="moreSelectorsOrButton();">
                <option value="">{{ section.settings.quantityDropdown }}</option>
            </select>
        </div>
        <button style="display: none;" onclick="processSelections();" id="offersAddToCart" class="product-form--atc-button">{{ section.settings.addButton }}</button>
      </div>
    </div>
