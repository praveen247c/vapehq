<div 
     data-placement_fullwidth="{%- if section.settings.placement_fullwidth -%}1{%- else -%}0{%- endif -%}"
     id="custom-widget-{{section.id}}" class="custom-widget-wrapper{%- if section.settings.visible_on_mobile == false -%}{{" hidden-xs"}}{%- endif-%}" data-section-id="{{ section.id }}" data-section-type="custom-widget">
  	{%- for block in section.blocks -%}
      <div class="custom-widget" {{ block.shopify_attributes }}>
        {%- if block.type == 'custom_html' -%}
  <div align="center" style="margin-top:20px;">
    <div class="homebannerparent">

      <!-- First Image Block -->
      <div class="homebanner-blocks">
        <a href="/collections/starter-vape-kits">
          <img src="https://cdn.shopify.com/s/files/1/2600/2254/files/Categories_Desktop_Kits.jpg?v=1732190428" class="homebannerimg">
        </a>
      </div>

      <!-- Second Image Block -->
      <div class="homebanner-blocks">
        <a href="/collections/10ml-e-liquid">
          <img src="https://cdn.shopify.com/s/files/1/2600/2254/files/Categories_Desktop_Liquid.jpg?v=1732190427" class="homebannerimg">
        </a>
      </div>
    </div>

    <div class="homebannerparent">

      <!-- Third Image Block -->
      <div class="homebanner-blocks">
        <a href="/collections/alternative-nicotine">
          <img src="https://cdn.shopify.com/s/files/1/2600/2254/files/Categories_Desktop_Smoke_Free.jpg?v=1732190428" class="homebannerimg">
        </a>
      </div>

      <!-- Fourth Image Block -->
      <div class="homebanner-blocks">
        <a href="/collections/big-puff-disposables">
          <img src="https://cdn.shopify.com/s/files/1/2600/2254/files/Categories_Desktop_Big_Puff.jpg?v=1732190428" class="homebannerimg">
        </a>
      </div>
    </div>

    <div class="homebannerparent">

      <!-- Fifth Image Block -->
      <div class="homebanner-blocks">
        <a href="/collections/spare-pods">
          <img src="https://cdn.shopify.com/s/files/1/2600/2254/files/Categories_Desktop_Pods.jpg?v=1732190428" class="homebannerimg">
        </a>
      </div>

      <!-- Sixth Image Block -->
      <div class="homebanner-blocks">
        <a href="/collections/spare-coils">
          <img src="https://cdn.shopify.com/s/files/1/2600/2254/files/Categories_Desktop_Coils_6bea7ddd-3d2b-431f-bf9a-901ada1288d2.jpg?v=1761930248" class="homebannerimg">
        </a>
      </div>
    </div>
  </div>
{%- else -%}
        	{{pages[block.settings.page_content].content}}
{%- endif -%}
      </div>
    {%- endfor -%}
</div>



{% schema %}
